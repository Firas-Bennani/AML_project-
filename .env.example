# =============================================================================
# AML Hybrid Platform — Environment Template
# =============================================================================
# Copy:   cp .env.example .env
# .env is gitignored. Replace placeholder values for any service you enable.
#
# Naming convention (non-negotiable):
#   AI_*       → variables consumed by the ai/ microservice
#   BACKEND_*  → variables consumed by the backend/ FastAPI service
#   (infra service vars stay un-prefixed: POSTGRES_*, REDIS_*, NEO4J_*, MILVUS_*)
# =============================================================================


# ─── HOST PORTS (host:container mapping in docker-compose) ──────────────────
FRONTEND_PORT=3000           # vite dev server is :5173 inside the container
BACKEND_PORT=8000
AI_PORT=8001
POSTGRES_PORT=5432
REDIS_PORT=6379
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
MILVUS_PORT=19530


# ============================================================================
# AI SERVICE  (ai/)
# ============================================================================

# Operating mode for /investigate.
#   true  → mock Neo4j/Milvus/LLM (works without external creds, default)
#   false → call real Neo4j + Milvus + NIM
AI_MOCK_EXTERNAL=true

AI_LOG_LEVEL=INFO
AI_GNN_CHECKPOINT=aml_model.pt
AI_GNN_TRIGGER_THRESHOLD=0.45
# AI_DETECT_THRESHOLDS overrides the per-typology cutoffs calibrated during
# training. Leave unset to use the checkpoint's calibrated values.
# Example: AI_DETECT_THRESHOLDS=0.50,0.65,0.55  (smurfing,structuring,layering)
#AI_DETECT_THRESHOLDS=

# ── Neo4j (only used when AI_MOCK_EXTERNAL=false) ──────────────────────────
AI_NEO4J_URI=bolt://neo4j:7687
AI_NEO4J_USER=neo4j
AI_NEO4J_PASSWORD=changeme_neo4j
AI_NEO4J_DATABASE=neo4j

# ── Milvus (only used when AI_MOCK_EXTERNAL=false) ─────────────────────────
AI_MILVUS_HOST=milvus
AI_MILVUS_PORT=19530
AI_MILVUS_USER=
AI_MILVUS_PASSWORD=
AI_MILVUS_COLLECTION_KYC=kyc_documents
AI_MILVUS_COLLECTION_NEWS=negative_news

# ── NVIDIA NIM (only used when AI_MOCK_EXTERNAL=false) ─────────────────────
AI_NIM_API_KEY=nvapi-replace-me
AI_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
AI_NIM_MODEL=meta/llama-3-70b-instruct
AI_NIM_TIMEOUT=60

# ── LangSmith tracing (optional) ───────────────────────────────────────────
AI_LANGCHAIN_TRACING_V2=false
AI_LANGCHAIN_API_KEY=
AI_LANGCHAIN_PROJECT=aml-investigator-agent


# ============================================================================
# BACKEND SERVICE  (backend/)
# ============================================================================

# Address of the AI microservice as seen from the backend container.
# In docker-compose this resolves to the service hostname.
BACKEND_AI_BASE_URL=http://ai:8001
BACKEND_AI_DETECT_TIMEOUT_SECONDS=10
BACKEND_AI_INVESTIGATE_TIMEOUT_SECONDS=60

# JWT
BACKEND_JWT_SECRET=replace-with-long-random-string
BACKEND_JWT_ALGORITHM=HS256
BACKEND_JWT_EXPIRE_MINUTES=480

# Database (SQLite for v1; postgres available but unused — see README)
BACKEND_DB_URL=sqlite:///./aml.db

# Risk flag threshold. A transaction whose risk_score is >= this value is
# auto-FLAGGED and triggers an alert. 0.5 catches more mid-risk activity than
# the legacy 0.7 default.
BACKEND_FLAG_THRESHOLD=0.5

# CORS
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173


# ============================================================================
# INFRA (used by docker-compose, optional consumers)
# ============================================================================

POSTGRES_USER=aml
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_DB=aml

REDIS_PASSWORD=

NEO4J_AUTH=neo4j/changeme_neo4j
NEO4J_PLUGINS=["apoc"]
