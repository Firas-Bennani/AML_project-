# =============================================================================
# AML HYBRID SYSTEM — Environment Configuration Template
# =============================================================================
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in real values in .env
#   3. NEVER commit .env — it is blocked by .gitignore
#
# SECURITY NOTE: This file (.env.example) contains ONLY placeholder values.
# It is safe to commit. The real .env is listed in .gitignore.
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# NEO4J — Graph Database (2-hop neighbourhood queries)
# ─────────────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=aml                    # leave blank to use default db


# ─────────────────────────────────────────────────────────────────────────────
# MILVUS — Vector Database (KYC docs + negative news RAG)
# ─────────────────────────────────────────────────────────────────────────────
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=                          # leave empty if no auth configured
MILVUS_PASSWORD=                      # leave empty if no auth configured
MILVUS_COLLECTION_KYC=kyc_documents
MILVUS_COLLECTION_NEWS=negative_news


# ─────────────────────────────────────────────────────────────────────────────
# NVIDIA NIM — LLM Inference (Llama-3-70B or Mixtral via NIM microservice)
# ─────────────────────────────────────────────────────────────────────────────
NVIDIA_NIM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=meta/llama-3-70b-instruct
NVIDIA_NIM_TIMEOUT=60                 # seconds before request times out
NVIDIA_NIM_MAX_TOKENS=2048


# ─────────────────────────────────────────────────────────────────────────────
# LANGCHAIN / LANGSMITH — Agent tracing & observability
# Set LANGCHAIN_TRACING_V2=true to send all LangGraph traces to LangSmith.
# Get your key at: https://smith.langchain.com/settings
# ─────────────────────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGCHAIN_PROJECT=aml-investigator-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com


# ─────────────────────────────────────────────────────────────────────────────
# LANGGRAPH — Checkpointing & Human-in-the-Loop
# ─────────────────────────────────────────────────────────────────────────────
LANGGRAPH_CHECKPOINT_DB=aml_checkpoints.db   # SQLite path (relative to project root)
LANGGRAPH_INTERRUPT_BEFORE=report            # node name to pause for human review


# ─────────────────────────────────────────────────────────────────────────────
# GNN / TRAINING — Model paths
# ─────────────────────────────────────────────────────────────────────────────
AML_GNN_CHECKPOINT=aml_model_v2.pt
AML_GNN_TRIGGER_THRESHOLD=0.85
AML_SAML_CSV_PATH=data/SAML-D.csv/SAML-D.csv


# ─────────────────────────────────────────────────────────────────────────────
# TRITON — Inference Server (optional, GPU production deployment)
# ─────────────────────────────────────────────────────────────────────────────
TRITON_SERVER_URL=localhost:8001      # gRPC endpoint
TRITON_MODEL_NAME=aml_hetero_sage
TRITON_MODEL_VERSION=1


# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION — General settings
# ─────────────────────────────────────────────────────────────────────────────
APP_ENV=development                   # development | staging | production
APP_LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
APP_SAR_OUTPUT_DIR=output/sar_reports
